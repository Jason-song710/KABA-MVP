POSTGRES_DB=address_notices
POSTGRES_USER=address_app
POSTGRES_PASSWORD=address_app

DATABASE_URL=postgresql+psycopg://address_app:address_app@db:5432/address_notices

OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

AUTH_SECRET_KEY=change-this-local-secret
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=admin1234

G2B_API_ENDPOINT=https://apis.data.go.kr/1230000/ad/BidPublicInfoService
G2B_API_KEY=
G2B_API_OPERATIONS=getBidPblancListInfoServcPPSSrch,getBidPblancListInfoThngPPSSrch,getBidPblancListInfoCnstwkPPSSrch
G2B_NUM_ROWS=100
G2B_INQRY_DIVS=1,2
G2B_MAX_PAGES_PER_OPERATION=5
G2B_RECENT_WINDOW_DAYS=1
G2B_DEADLINE_WINDOW_DAYS=30
G2B_AUTO_COLLECT_ENABLED=true
G2B_AUTO_COLLECT_INTERVAL_MINUTES=60
G2B_AUTO_COLLECT_ON_STARTUP=true
G2B_AUTO_COLLECT_RUN_AI=false

CORS_ORIGINS=http://localhost:3000,http://localhost:5173
SEED_SAMPLE_DATA=false
